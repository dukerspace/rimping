{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "rimping hooks pre-send",
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "command": "rimping hooks pre-shell",
        "matcher": "Shell",
        "timeout": 10
      },
      {
        "command": "rimping hooks pre-read",
        "matcher": "Read",
        "timeout": 10
      }
    ],
    "postToolUse": [
      {
        "command": "rimping hooks post-read",
        "matcher": "Read",
        "timeout": 10
      }
    ]
  }
}
